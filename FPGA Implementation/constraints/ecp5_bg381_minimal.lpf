# Example clock constraint (edit frequency for your oscillator)
# FREQUENCY PORT "clk_in" 25.000 MHz;

# Pin assignments (PLACEHOLDERS - replace with real pins!)
# LOCATE COMP "clk_in" SITE "A1";
# IOBUF PORT "clk_in" IO_TYPE=LVCMOS33;

# LOCATE COMP "rst_n" SITE "B1";
# IOBUF PORT "rst_n" IO_TYPE=LVCMOS33;

